{
  "compilerOptions": {
    "strict": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "noUncheckedIndexedAccess": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "paths": {
      "@frontend-monorepo-showcase/design-tokens": ["./packages/design-tokens/src/index.ts"],
      "@frontend-monorepo-showcase/design-tokens/css/layers": ["./packages/design-tokens/src/layers.css"],
      "@frontend-monorepo-showcase/design-tokens/css": ["./packages/design-tokens/src/tokens.css"],
      "@frontend-monorepo-showcase/design-tokens/css/dark": ["./packages/design-tokens/src/dark.css"],
      "@frontend-monorepo-showcase/ui-core": ["./packages/ui-core/src/index.ts"],
      "@frontend-monorepo-showcase/mock-engine": ["./packages/mock-engine/src/index.ts"],
      "@frontend-monorepo-showcase/perf-guardian": ["./packages/perf-guardian/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "dist"]
}
